<div class="container-fluid">
  <h1 class="mb-4">Quản lý tài khoản</h1>
  
  <div class="mb-3">
    <a href="/admin/accounts/new" class="btn btn-success">
      <i class="fas fa-plus"></i> Tạo tài khoản mới
    </a>
  </div>
  
  <div class="card">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead>
            <tr>
              <th>Username</th>
              <th>Vai trò</th>
              <th>Team</th>
              <th>Trạng thái</th>
              <th>Ngày tạo</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td><%= user.username %></td>
                <td><%= user.role === 'admin' ? 'Admin' : 'User' %></td>
                <td><%= user.team ? user.team.name : 'Chưa phân team' %></td>
                <td>
                  <span class="badge <%= user.active ? 'bg-success' : 'bg-danger' %>">
                    <%= user.active ? 'Hoạt động' : 'Đã khóa' %>
                  </span>
                </td>
                <td><%= new Date(user.createdAt).toLocaleString('vi-VN') %></td>
                <td>
                  <a href="/admin/accounts/<%= user._id %>/edit" class="btn btn-sm btn-primary">Sửa</a>
                  <% if (user.role !== 'admin') { %>
                    <button class="btn btn-sm btn-danger delete-user" data-id="<%= user._id %>">Xóa</button>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const deleteButtons = document.querySelectorAll('.delete-user');
    
    deleteButtons.forEach(button => {
      button.addEventListener('click', function() {
        const userId = this.getAttribute('data-id');
        
        if (confirm('Bạn có chắc chắn muốn xóa người dùng này?')) {
          fetch(`/admin/accounts/${userId}`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            }
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              alert('Xóa người dùng thành công');
              window.location.reload();
            } else {
              alert('Lỗi: ' + data.message);
            }
          })
          .catch(error => {
            console.error('Error:', error);
            alert('Đã xảy ra lỗi khi xóa người dùng');
          });
        }
      });
    });
  });
</script>