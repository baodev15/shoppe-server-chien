<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Accounts Upload Video</h1>
    <form method="GET" action="/shopee-accounts/upload-video" class="d-flex" style="max-width: 320px;">
      <input type="text" class="form-control form-control-sm me-2" name="search" value="<%= search || '' %>"
        placeholder="Tìm theo username">
      <button class="btn btn-sm btn-primary" type="submit">Tìm</button>
    </form>
  </div>
  <div class="d-flex gap-2 mb-2">
    <button class="btn btn-sm btn-danger" id="deleteSelectedBtn" disabled>Xóa selected</button>
    <button class="btn btn-sm btn-success" id="enableUploadSelectedBtn" disabled>Enable Is Upload API</button>
    <button class="btn btn-sm btn-secondary" id="disableUploadSelectedBtn" disabled>Disable Is Upload API</button>
  </div>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="text-center"><input type="checkbox" id="selectAllAccounts"></th>
              <th>Username</th>
              <th>User ID</th>
              <th>Shop ID</th>
              <th>Cookie Live</th>
              <th>Time Update Cookie</th>
              <th>Is Upload API</th>
              <th>Videos Uploaded</th>
              <th>Daly Videos Uploaded</th>
              <th>Trạng thái Upload</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (accounts && accounts.length) { %>
              <% accounts.forEach(account=> { %>
                <tr>
                  <td class="text-center">
                    <input class="form-check-input account-checkbox" type="checkbox" value="<%= account._id %>">
                  </td>
                  <td>
                    <%= account.username || '-' %>
                  </td>
                  <td><code><%= account.user_id || '-' %></code></td>
                  <td><code><%= account.shop_id || '-' %></code></td>
                  <td>
                    <% if (account.cookie_live) { %>
                      <span class="badge bg-success">Đã có</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Trống</span>
                        <% } %>
                  </td>
                  <% const rawTimeUpdateCookie=account.time_update_cookie; let cookieUpdateDate=null; if
                    (rawTimeUpdateCookie !==null && rawTimeUpdateCookie !==undefined && rawTimeUpdateCookie !=='' ) {
                    const numericTimestamp=Number(rawTimeUpdateCookie); if (!Number.isNaN(numericTimestamp)) {
                    cookieUpdateDate=new Date(numericTimestamp> 9999999999 ? numericTimestamp : numericTimestamp *
                    1000);
                    } else {
                    cookieUpdateDate = new Date(rawTimeUpdateCookie);
                    }
                    }
                    const isValidCookieUpdateDate = cookieUpdateDate && !Number.isNaN(cookieUpdateDate.getTime());
                    const isCookieUpdateWithinOneHour = isValidCookieUpdateDate && ((Date.now() -
                    cookieUpdateDate.getTime()) <= 60 * 60 * 1000); const
                      isCookieUpdateOlderThanOneDay=isValidCookieUpdateDate && ((Date.now() -
                      cookieUpdateDate.getTime())> 24 * 60 * 60 * 1000);
                      const displayedTimeUpdateCookie = isValidCookieUpdateDate
                      ? `${String(cookieUpdateDate.getHours()).padStart(2,
                      '0')}:${String(cookieUpdateDate.getMinutes()).padStart(2,
                      '0')}:${String(cookieUpdateDate.getSeconds()).padStart(2, '0')}
                      ${String(cookieUpdateDate.getDate()).padStart(2, '0')}/${String(cookieUpdateDate.getMonth() +
                      1).padStart(2, '0')}/${cookieUpdateDate.getFullYear()}`
                      : (rawTimeUpdateCookie || '-');
                      %>
                      <td id="time-update-cookie-<%= account._id %>"
                        class="<%= isCookieUpdateWithinOneHour ? 'text-success fw-bold' : (isCookieUpdateOlderThanOneDay ? 'text-danger fw-bold' : '') %>">
                        <%= displayedTimeUpdateCookie %>
                      </td>
                      <td>

                        <div class="form-check form-switch mt-1">
                          <input class="form-check-input toggle-is-upload-api" type="checkbox"
                            data-id="<%= account._id %>" <%=account.is_upload_api ? 'checked' : '' %>
                          >
                          <span id="upload-api-status-<%= account._id %>"
                            class="badge <%= account.is_upload_api ? 'bg-success' : 'bg-danger' %>">
                            <%= account.is_upload_api ? 'allow upload' : 'disable' %>
                          </span>
                        </div>
                      </td>
                      <td>
                        <%= Number(account.totalVideosUploaded || 0).toLocaleString('vi-VN') %>
                      </td>
                      <td>
                        <%= Number(account.dalyVideosUploaded || 0).toLocaleString('vi-VN') %>
                      </td>
                      <td>
                        <%= account.last_status_upload || '----' %>
                      </td>
                      <td>
                        <button type="button" class="btn btn-sm btn-outline-primary view-logs-btn"
                          data-user-id="<%= account.user_id || '' %>" data-username="<%= account.username || '' %>">
                          <i class="fas fa-list"></i> Logs
                        </button>
                      </td>
                </tr>
                <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="11" class="text-center text-muted py-4">Không có dữ liệu</td>
                    </tr>
                    <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="accountLogsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content" style="min-height: 80vh; padding: 20px;">
      <div class="modal-header">
        <h5 class="modal-title">Logs - <span id="accountLogsModalTitle">-</span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <div class="d-flex justify-content-end p-2 border-bottom">
          <button class="btn btn-sm btn-outline-secondary" id="refreshAccountLogsBtn">Refresh</button>
        </div>
        <div class="table-responsive">
          <table class="table table-striped table-hover mb-0" id="apiLogsTable">
            <thead class="table-light">
              <tr>
                <th>Time</th>
                <th>Username</th>
                <th>Status</th>
                <th style="width: 45%;">Message</th>
                <th>Job ID</th>
                <th>Source</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td colspan="6" class="text-center text-muted py-3">Chọn account để xem log</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const toggles = document.querySelectorAll('.toggle-is-upload-api');
    const viewLogsButtons = document.querySelectorAll('.view-logs-btn');
    const selectAllAccounts = document.getElementById('selectAllAccounts');
    const accountCheckboxes = document.querySelectorAll('.account-checkbox');
    const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');
    const enableUploadSelectedBtn = document.getElementById('enableUploadSelectedBtn');
    const disableUploadSelectedBtn = document.getElementById('disableUploadSelectedBtn');
    const refreshAccountLogsBtn = document.getElementById('refreshAccountLogsBtn');
    const accountLogsModalTitle = document.getElementById('accountLogsModalTitle');
    const accountLogsModalElement = document.getElementById('accountLogsModal');
    const accountLogsModal = accountLogsModalElement ? new bootstrap.Modal(accountLogsModalElement) : null;
    let currentLogsUserId = '';
    let currentLogsUsername = '';

    function getSelectedAccountIds() {
      return Array.from(document.querySelectorAll('.account-checkbox:checked')).map(el => el.value);
    }

    function updateSelectedState() {
      const total = accountCheckboxes.length;
      const checked = document.querySelectorAll('.account-checkbox:checked').length;
      const hasSelection = checked > 0;
      deleteSelectedBtn.disabled = !hasSelection;
      enableUploadSelectedBtn.disabled = !hasSelection;
      disableUploadSelectedBtn.disabled = !hasSelection;
      if (selectAllAccounts) {
        selectAllAccounts.checked = total > 0 && checked === total;
        selectAllAccounts.indeterminate = checked > 0 && checked < total;
      }
    }

    if (selectAllAccounts) {
      selectAllAccounts.addEventListener('change', function () {
        accountCheckboxes.forEach(cb => {
          cb.checked = this.checked;
        });
        updateSelectedState();
      });
    }

    accountCheckboxes.forEach(cb => {
      cb.addEventListener('change', updateSelectedState);
    });

    toggles.forEach(toggle => {
      toggle.addEventListener('change', async function () {
        const accountId = this.getAttribute('data-id');
        const enabled = this.checked;
        this.disabled = true;
        try {
          const response = await fetch(`/shopee-accounts/upload-video/${accountId}/toggle-upload-api`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ enabled })
          });
          const result = await response.json();
          if (!result.success) {
            throw new Error(result.message || 'Update failed');
          }
          const target = document.getElementById(`upload-api-status-${accountId}`);
          if (target) {
            if (result.is_upload_api) {
              target.textContent = 'allow upload';
              target.classList.remove('bg-danger');
              target.classList.add('bg-success');
            } else {
              target.textContent = 'disable';
              target.classList.remove('bg-success');
              target.classList.add('bg-danger');
            }
          }
        } catch (error) {
          this.checked = !enabled;
          alert('Không cập nhật được is_upload_api');
        } finally {
          this.disabled = false;
        }
      });
    });

    async function batchToggleUploadApi(enabled) {
      const accountIds = getSelectedAccountIds();
      if (!accountIds.length) {
        return;
      }
      try {
        const response = await fetch('/shopee-accounts/upload-video/batch-toggle-upload-api', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ accountIds, enabled })
        });
        const result = await response.json();
        if (!result.success) {
          throw new Error(result.message || 'Update failed');
        }
        window.location.reload();
      } catch (error) {
        alert('Không cập nhật được selected accounts');
      }
    }

    deleteSelectedBtn.addEventListener('click', async function () {
      const accountIds = getSelectedAccountIds();
      if (!accountIds.length) {
        return;
      }
      if (!confirm(`Xóa ${accountIds.length} tài khoản đã chọn?`)) {
        return;
      }
      try {
        const response = await fetch('/shopee-accounts/upload-video/bulk-delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ accountIds })
        });
        const result = await response.json();
        if (!result.success) {
          throw new Error(result.message || 'Delete failed');
        }
        window.location.reload();
      } catch (error) {
        alert('Không xóa được selected accounts');
      }
    });

    enableUploadSelectedBtn.addEventListener('click', function () {
      batchToggleUploadApi(true);
    });

    disableUploadSelectedBtn.addEventListener('click', function () {
      batchToggleUploadApi(false);
    });

    function formatLogTime(value) {
      if (!value) return '-';
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return String(value);
      return `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}:${String(d.getSeconds()).padStart(2, '0')} ${String(d.getDate()).padStart(2, '0')}/${String(d.getMonth() + 1).padStart(2, '0')}/${d.getFullYear()}`;
    }

    function getStatusBadge(status) {
      const value = (status || '').toString().toLowerCase();
      if (['success', 'ok', 'uploaded', 'done'].includes(value)) {
        return '<span class="badge bg-success">success</span>';
      }
      if (['error', 'failed', 'fail'].includes(value)) {
        return '<span class="badge bg-danger">error</span>';
      }
      if (['warning', 'warn'].includes(value)) {
        return '<span class="badge bg-warning text-dark">warning</span>';
      }
      return `<span class="badge bg-secondary">${status || '-'}</span>`;
    }

    async function loadApiLogs(username = '') {
      const tbody = document.querySelector('#apiLogsTable tbody');
      const params = new URLSearchParams();
      params.set('limit', '300');
      if (username) {
        params.set('username', username);
      }
      tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Đang tải logs...</td></tr>';
      try {
        const response = await fetch(`/shopee-accounts/upload-video/logs?${params.toString()}`);
        const result = await response.json();
        if (!result.success) {
          throw new Error(result.message || 'Load logs failed');
        }
        const logs = Array.isArray(result.data) ? result.data : [];
        if (!logs.length) {
          tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Chưa có log</td></tr>';
          return;
        }
        tbody.innerHTML = logs.map(log => `
          <tr>
            <td>${formatLogTime(log.createdAt)}</td>
            <td>${log.username || '-'}</td>
            <td>${getStatusBadge(log.status)}</td>
            <td style="width: 45%; white-space: normal; word-break: break-word;">${log.message || '-'}</td>
            <td>${log.job_id || '-'}</td>
            <td>${log.source || '-'}</td>
          </tr>
        `).join('');
      } catch (error) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-danger py-3">Không tải được log</td></tr>';
      }
    }

    viewLogsButtons.forEach(btn => {
      btn.addEventListener('click', function () {
        const username = this.getAttribute('data-username') || '-';
LogsUsername = username;
        if (accountLogsModalTitle) {
          accountLogsModalTitle.textContent = `${username}`;
        }
        loadApiLogs(currentLogsUsername);
        if (accountLogsModal) {
          accountLogsModal.show();
        }
      });
    });

    if (refreshAccountLogsBtn) {
      refreshAccountLogsBtn.addEventListener('click', function () {
        loadApiLogs(currentLogsUserId, currentLogsUsername);
      });
    }

    updateSelectedState();
  });
</script>
