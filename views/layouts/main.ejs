<!DOCTYPE html>
<html lang="en">
<head>
    <base href="/">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Shopee API' %></title>
    <!-- Add Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Add Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Add your custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Global styles for fixed sidebar layout with smaller size */
        html, body {
            height: 100%;
            width: 100%;
            margin: 0;
            padding: 0;
            overflow: hidden;
            font-size: 14px; /* Reduced base font size */
        }
        
        .app-container {
            display: flex;
            height: 100vh;
            width: 100%;
            overflow: hidden;
        
        }
        
        .main-content-wrapper {
            flex: 1;
            margin-left: 10px;
            overflow-y: auto;
            overflow-x: hidden;
            height: 100vh;
            transition: margin-left 0.3s ease;
        }
        
        body.sidebar-collapsed .main-content-wrapper {
            margin-left: 30px;
        }
        
        .main-content {
            min-height: 100vh;
            padding: 10px ;
        }
        
        /* Scale down Bootstrap components */
        .btn {
            padding: 0.35rem 0.75rem;
            font-size: 0.75rem;
        }
        
        .form-control, .form-select {
            font-size: 1rem;
        }
        
        .card-header {
            padding: 0.5rem 0.75rem;
        }
        
        .card-body {
            padding: 0.75rem;
        }
        
        .table {
            font-size: 0.85rem;
        }
        
        .table td, .table th {
            padding: 0.5rem;
        }
        
        h1, .h1 {
            font-size: 1.5rem;
        }
        
        h3, .h3 {
            font-size: 1.25rem;
        }
        
        h5, .h5 {
            font-size: 1rem;
        }
        
        /* Responsive adjustments */
        @media (max-width: 768px) {
            .main-content-wrapper {
                margin-left: 0;
            }
            
            body.sidebar-collapsed .main-content-wrapper {
                margin-left: 0;
            }
            
        
        }
        
        /* Sidebar adjustments */
        .sidebar {
            font-size: 12px;
        }
        
        .sidebar-header {
            padding: 10px;
        }
        
        .sidebar-header h3 {
            font-size: 1.1rem;
        }
        
        .menu-item-header, .submenu-item {
            padding: 8px 15px;
        }
        
        .logout-btn {
            padding: 10px 15px;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Include Sidebar -->
        <%- include('../partials/sidebar') %>
        
        <div class="main-content-wrapper">
            <div class="main-content">
                <%- body %>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Handle sidebar menu toggle
        document.addEventListener('DOMContentLoaded', function() {
            const menuHeaders = document.querySelectorAll('.menu-item-header');
            
            menuHeaders.forEach(header => {
                header.addEventListener('click', function() {
                    this.classList.toggle('active');
                    const submenu = this.nextElementSibling;
                    
                    if (submenu && submenu.classList.contains('submenu')) {
                        if (submenu.style.maxHeight) {
                            submenu.style.maxHeight = null;
                        } else {
                            submenu.style.maxHeight = submenu.scrollHeight + "px";
                        }
                    }
                });
            });
            
            // Expand active menu on page load
            const activeMenu = document.querySelector('.menu-item-header.active');
            if (activeMenu) {
                const submenu = activeMenu.nextElementSibling;
                if (submenu && submenu.classList.contains('submenu')) {
                    submenu.style.maxHeight = submenu.scrollHeight + "px";
                }
            }
        });
    </script>
    
    <!-- Additional scripts -->
    <%- typeof extraScripts !== 'undefined' ? extraScripts : '' %>
</body>
</html>