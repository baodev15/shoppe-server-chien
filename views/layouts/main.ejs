<!DOCTYPE html>
<html lang="en">
<head>
    <base href="/">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Shopee API' %></title>
    <!-- Add Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Add Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Add your custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Global styles for fixed sidebar layout with smaller size */
        html, body {
            height: 100%;
            width: 100%;
            margin: 0;
            padding: 0;
            overflow: hidden;
            font-size: 14px; /* Reduced base font size */
        }
        
        .app-container {
            display: flex;
            height: 100vh;
            width: 100%;
            overflow: hidden;
        
        }
        
        .main-content-wrapper {
            flex: 1;
            margin-left: 230px;
            display: flex;
            flex-direction: column;
            height: 100vh;
            transition: margin-left 0.3s ease;
        }
        
        .header-section {
            flex-shrink: 0;
            background: linear-gradient(180deg, #ffffff 0%, #fff7f3 100%);
            border-bottom: 1px solid #ffd8ca;
            padding: 10px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 14px rgba(238, 77, 45, 0.08);
            backdrop-filter: blur(2px);
            min-height: 56px;
        }

        .header-title {
            display: flex;
            align-items: center;
            gap: 8px;
            min-width: 0;
        }

        .header-chip {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: linear-gradient(180deg, #ff7a45 0%, #ee4d2d 100%);
            color: #fff;
            font-size: 12px;
            flex-shrink: 0;
            box-shadow: 0 6px 14px rgba(238, 77, 45, 0.25);
        }

        .header-title-text {
            font-size: 14px;
            font-weight: 700;
            color: #3c2a23;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .user-role-badge {
            font-size: 11px;
            font-weight: 600;
            padding: 6px 10px;
            border-radius: 999px;
            background: linear-gradient(180deg, #ff7a45 0%, #ee4d2d 100%);
            color: #fff;
            border: 1px solid rgba(238, 77, 45, 0.32);
        }

        .user-name {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #4d3a34;
            font-size: 13px;
            font-weight: 600;
            padding: 6px 10px;
            border-radius: 999px;
            background: #fff;
            border: 1px solid #ffd8ca;
        }

        .team-id {
            font-size: 11px;
            font-weight: 600;
            border-radius: 999px;
            padding: 6px 10px;
            background: #fff;
            color: #ee4d2d;
            border: 1px solid #ffd8ca;
        }
        
        .main-content {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 10px;
        }

        div.app-container > div.main-content-wrapper > div.main-content {
            margin-left: 0px;
        }
        
        body.sidebar-collapsed .main-content-wrapper {
            margin-left: 64px;
        }
        

        
        /* Scale down Bootstrap components */
        .btn {
            padding: 0.35rem 0.75rem;
            font-size: 0.75rem;
        }
        
        .form-control, .form-select {
            font-size: 1rem;
        }
        
        .card-header {
            padding: 0.5rem 0.75rem;
        }
        
        .card-body {
            padding: 0.75rem;
        }
        
        .table {
            font-size: 0.85rem;
        }
        
        .table td, .table th {
            padding: 0.5rem;
        }
        
        h1, .h1 {
            font-size: 1.5rem;
        }
        
        h3, .h3 {
            font-size: 1.25rem;
        }
        
        h5, .h5 {
            font-size: 1rem;
        }
        
        /* Responsive adjustments */
        @media (max-width: 768px) {
            .main-content-wrapper {
                margin-left: 0;
            }
            
            body.sidebar-collapsed .main-content-wrapper {
                margin-left: 0;
            }
            
        
        }
        
        /* Sidebar adjustments */
        .sidebar {
            font-size: 12px;
        }
        
        .sidebar-header {
            padding: 10px;
        }
        
        .sidebar-header h3 {
            font-size: 1.1rem;
        }
        
        .menu-item-header, .submenu-item {
            padding: 8px 15px;
        }
        
        .logout-btn {
            padding: 10px 15px;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Include Sidebar -->
        <%- include('../partials/sidebar') %>
        
        <div class="main-content-wrapper">
            <!-- Header Section -->
            <header class="header-section">
                <div class="header-title">
                    <span class="header-chip"><i class="fas fa-sparkles"></i></span>
                    <span class="header-title-text"><%= typeof title !== 'undefined' ? title : 'Shopee Tool Dashboard' %></span>
                </div>
                <div class="user-info">
                    <% if (locals.user) { %>
                        <% if (locals.user.role === 'admin' || locals.user.role === 'super_admin') { %>
                            <span class="user-role-badge"><%= locals.user.role === 'super_admin' ? 'Super Admin' : 'Admin' %></span>
                        <% } else { %>
                            <span class="user-name">
                                <i class="fas fa-user"></i>
                                Xin Chào <%= user.username %>
                            </span>
                            <% if (user.team && user.team._id) { %>
                                <span class="team-id" title="Team ID">
                                    <i class="fas fa-users"></i>
                                    <%= user.team._id %>
                                </span>
                            <% } %>
                        <% } %>
                    <% } %>
                </div>
            </header>
            
            <div class="main-content">
                <%- body %>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Handle sidebar menu toggle
        document.addEventListener('DOMContentLoaded', function() {
            const menuHeaders = document.querySelectorAll('.menu-item-header');
            
            menuHeaders.forEach(header => {
                header.addEventListener('click', function() {
                    this.classList.toggle('active');
                    const submenu = this.nextElementSibling;
                    
                    if (submenu && submenu.classList.contains('submenu')) {
                        if (submenu.style.maxHeight) {
                            submenu.style.maxHeight = null;
                        } else {
                            submenu.style.maxHeight = submenu.scrollHeight + "px";
                        }
                    }
                });
            });
            
            // Expand active menu on page load
            const activeMenu = document.querySelector('.menu-item-header.active');
            if (activeMenu) {
                const submenu = activeMenu.nextElementSibling;
                if (submenu && submenu.classList.contains('submenu')) {
                    submenu.style.maxHeight = submenu.scrollHeight + "px";
                }
            }
        });
    </script>
    
    <!-- Additional scripts -->
    <%- typeof extraScripts !== 'undefined' ? extraScripts : '' %>
</body>
</html>
